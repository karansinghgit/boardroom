# Copy to .env and fill in. Only needed for live runs (the test and eval
# suites run fully offline without any key).

# API key for the language model provider.
ANTHROPIC_API_KEY=

# Optional model overrides. Defaults are set in src/boardroom/config.py.
# A fast, cheaper model is used for analysts and investors; a stronger model
# is used for the final portfolio decision.
BOARDROOM_FAST_MODEL=
BOARDROOM_DEEP_MODEL=
